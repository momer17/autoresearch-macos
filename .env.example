# GCP / Vertex AI — required for all Claude API calls
ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_REGION=us-east5

# Tavily — required for research agent web search
TAVILY_API_KEY=tvly-your-key-here

# Experiment config
TOTAL_ITERATIONS=8
EVALUATE_TIMEOUT_SECONDS=60

# GCP service account key — required on the GPU machine (Vast.ai)
# On the GPU: scp ~/autoresearch-key.json root@<gpu-ip>:/root/autoresearch-key.json
# then set this path below. Local dev can leave this blank if using gcloud auth.
GOOGLE_APPLICATION_CREDENTIALS=/root/autoresearch-key.json

# Note: Do NOT add ANTHROPIC_API_KEY — we use Vertex, not direct Anthropic
# Local dev: authenticate via gcloud auth application-default login
# GPU machine: use the service account key above
